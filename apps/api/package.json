{
  "name": "@arc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@arc/arc-engine": "workspace:*",
    "@arc/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^8.0.0",
    "@libsql/client": "^0.14.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "nanoid": "^5.0.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@sqlitecloud/drivers": "^1.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
